@import "tailwindcss";

@theme {
  --color-primary: #3b82f6;
  --color-primary-dark: #2563eb;
  --color-primary-light: #60a5fa;
  
  --color-secondary: #10b981;
  --color-secondary-dark: #059669;
  --color-secondary-light: #34d399;
  
  --color-background-custom: #ffffff;
  --color-background-alt: #f8fafc;
  --color-background-custom-dark: #0f172a;
  
  --color-accent: #8b5cf6;
  --color-accent-dark: #7c3aed;
  --color-accent-light: #a78bfa;

  --font-sans: "Inter", "system-ui", "sans-serif";
  --font-display: "Outfit", "sans-serif";
}

@layer base {
  html {
    scroll-behavior: smooth;
  }
  
  body {
    background-color: var(--color-background-custom);
    color: #0f172a; /* slabte-900 */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-family: var(--font-sans);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    font-weight: 700;
  }
}

@layer components {
  .section-padding {
    @apply py-20 px-6 max-w-7xl mx-auto;
  }
  
  .glass-card {
    @apply bg-white/80 backdrop-blur-md border border-slate-200 rounded-2xl shadow-sm;
  }

  .btn-primary {
    @apply px-6 py-3 bg-primary text-white rounded-full font-semibold transition-all hover:bg-primary-dark hover:shadow-lg active:scale-95;
  }

  .btn-secondary {
    @apply px-6 py-3 border-2 border-primary text-primary rounded-full font-semibold transition-all hover:bg-primary/5 active:scale-95;
  }
}
